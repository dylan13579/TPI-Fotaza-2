extends layout

block styles
  link(rel='stylesheet', href='/css/login.css')

block content

  .row.justify-content-center
    .col-md-4
      .card.shadow
        .card-body

          h2.mb-4 Login

          if success
            .alert.alert-success= success

          if errores && errores.general
            .alert.alert-danger= errores.general

          form(method='POST' novalidate)

            .mb-3
              input.form-control(
                class=errores && errores.email ? 'is-invalid' : ''
                type='email'
                name='email'
                placeholder='Email'
                value=datos ? datos.email : ''
              )
              if errores && errores.email
                .invalid-feedback= errores.email

            .mb-3
              input.form-control(
                class=errores && errores.password ? 'is-invalid' : ''
                type='password'
                name='password'
                placeholder='Contraseña'
              )
              if errores && errores.password
                .invalid-feedback= errores.password

            button.btn.btn-primary.w-100(type='submit')
              | Ingresar

          a.btn.btn-outline-secondary.w-100.mt-2(href='/auth/register')
            | Crear cuenta