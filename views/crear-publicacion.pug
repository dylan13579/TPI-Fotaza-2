extends layout

block styles
  link(rel='stylesheet', href='/css/crear-publicacion.css')

block content
  .create-container

    .create-card
      h2 Crear publicación

      form(method='POST' action='/publicaciones/crear')

        .input-group
          input.form-control(
            type='text'
            name='titulo'
            placeholder='¿Qué estás pensando?'
            required
          )

        .input-group
          textarea.form-control(
            name='descripcion'
            placeholder='Escribí una descripción...'
            rows='3'
          )

        .upload-box(id='uploadBox')
          input(
            type='file'
            id='fileInput'
            accept='image/*'
            hidden
          )

          .upload-content
            i.bi.bi-image
            p Arrastrá una imagen o hacé click
            small JPG, PNG

          img#preview(style='display:none;')

        input(type='hidden' name='imagen' id='imagenBase64')

        button.btn-publish(type='submit')
          | Publicar

  script.
    const fileInput = document.getElementById('fileInput');
    const uploadBox = document.getElementById('uploadBox');
    const preview = document.getElementById('preview');
    const base64Input = document.getElementById('imagenBase64');

    uploadBox.addEventListener('click', () => fileInput.click());

    uploadBox.addEventListener('dragover', e => {
      e.preventDefault();
      uploadBox.classList.add('drag');
    });

    uploadBox.addEventListener('dragleave', () => {
      uploadBox.classList.remove('drag');
    });

    uploadBox.addEventListener('drop', e => {
      e.preventDefault();
      uploadBox.classList.remove('drag');
      const file = e.dataTransfer.files[0];
      handleFile(file);
    });

    fileInput.addEventListener('change', e => {
      const file = e.target.files[0];
      handleFile(file);
    });

    function handleFile(file) {
      if (!file) return;

      const reader = new FileReader();

      reader.onloadend = function() {
        preview.src = reader.result;
        preview.style.display = 'block';
        base64Input.value = reader.result;
        uploadBox.classList.add('has-image');
      };

      reader.readAsDataURL(file);
    }