doctype html
html
  head
    title Fotaza2

    link(
      rel='stylesheet'
      href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css'
    )

    link(
      rel='stylesheet'
      href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css'
    )


  body.bg-light

    nav.navbar.navbar-dark.bg-dark
      .container

        a.navbar-brand(href='/')
          | Fotaza2

        .d-flex

          if usuario
            a.btn.btn-outline-light.me-2(
              href='/publicaciones'
            )
              | Publicaciones

            a.btn.btn-success.me-2(
              href='/publicaciones/crear'
            )
              | Crear

            a.btn.btn-danger(
              href='/auth/logout'
            )
              | Logout

          else

            a.btn.btn-outline-light.me-2(
              href='/auth/login'
            )
              | Login

            a.btn.btn-primary(
              href='/auth/register'
            )
              | Registro

    .container.mt-4
      block content