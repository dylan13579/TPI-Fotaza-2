doctype html
html
  head
    title Fotaza

    link(rel='stylesheet', href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css')
    link(rel='stylesheet', href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css')

    link(rel='stylesheet', href='/css/sidebar.css')

    block styles

  body.bg-light

    if !ocultarSidebar
      .sidebar.text-white

        .sidebar-header
          .logo F

        .search-box.mb-3
          i.bi.bi-search
          input(
            type='search'
            placeholder='Buscar...'
            oninput='buscarPublicaciones(this.value)'
          )

        hr.sidebar-divider

        if usuario

          a.sidebar-item(href='/publicaciones')
            i.bi.bi-grid
            span.texto Publicaciones

          a.sidebar-item(href='/publicaciones/crear')
            i.bi.bi-plus-circle
            span.texto Crear

          a.sidebar-item(href='/notificaciones')
            i.bi.bi-bell
            span.texto Notificaciones

            if notificacionesNoLeidas && notificacionesNoLeidas > 0
              span.badge.bg-danger= notificacionesNoLeidas

          a.sidebar-item.logout(href='/auth/logout')
            i.bi.bi-box-arrow-right
            span.texto Salir

        else

          a.sidebar-item(href='/auth/login')
            i.bi.bi-box-arrow-in-right
            span.texto Login

          a.sidebar-item(href='/auth/register')
            i.bi.bi-person-plus
            span.texto Registro

    .main-content(class=ocultarSidebar ? '' : 'con-sidebar')
      .container.mt-4
        block content

    script.
      let timeout;

      function buscarPublicaciones(texto) {
        clearTimeout(timeout);

        timeout = setTimeout(async () => {
          const contenedor = document.getElementById('contenedor-publicaciones');

          if (!texto) return location.reload();

          const res = await fetch(`/publicaciones/buscar?q=${texto}`);
          const html = await res.text();

          const temp = document.createElement('div');
          temp.innerHTML = html;

          const nuevas = temp.querySelector('#contenedor-publicaciones');

          if (nuevas) contenedor.innerHTML = nuevas.innerHTML;
        }, 300);
      }