doctype html
html
  head
    title Fotaza

    link(
      rel='stylesheet'
      href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css'
    )

    link(
      rel='stylesheet'
      href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css'
    )

    link(
      rel='stylesheet'
      href='/css/animacion.css'
    )

  body.bg-light

    nav.navbar.navbar-dark.bg-dark
      .container

        a.navbar-brand(href='/')
          | Fotaza

        .d-flex

          if !usuario

            a.btn.btn-outline-light.me-2(href='/auth/login')
              | Login

            a.btn.btn-primary(href='/auth/register')
              | Registro

    .container.mt-4
      block content